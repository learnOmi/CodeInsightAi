# 环境变量配置示例
# 复制为 .env 后填写实际值
# ⚠️ 生产环境必须配置 POSTGRES_PASSWORD、SECRET_KEY、API_KEY、LLM_API_KEY

# ============================================================
# 应用
# ============================================================
APP_ENV=development
DEBUG=true

# ============================================================
# 数据库 (PostgreSQL + pgvector)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=codeinsight
POSTGRES_USER=codeinsight
POSTGRES_PASSWORD=
# ⚠️ 生产环境必须配置，使用 32+ 字符随机密码

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_POOL_MAX_CONNECTIONS=50
REDIS_POOL_SOCKET_TIMEOUT=2

# ============================================================
# Meilisearch
# ============================================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=
# ⚠️ 生产环境建议配置

# ============================================================
# LLM（必须配置至少一个）
# ============================================================
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxxx
LLM_API_BASE=  # 自定义 API 端点（中转站/私有部署），留空使用 litellm 默认
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# ============================================================
# 本地模型（可选，需运行 Ollama）
# ============================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================
# JWT（预留，后续用户系统启用）
# ============================================================
# ⚠️ 生产环境必须配置，使用 32+ 字符随机值
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# API Key 认证
# ============================================================
# ⚠️ 生产环境必须配置；留空时跳过认证（仅开发环境）
API_KEY=

# ============================================================
# CORS
# ============================================================
# CORS 允许的来源（JSON 数组格式，或逗号分隔字符串）
CORS_ORIGINS=["http://localhost:3000"]
# CORS_ORIGINS=["http://localhost:3000","https://example.com"]
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key

# ============================================================
# 文件上传
# ============================================================
MAX_REPOSITORY_PATH_LENGTH=500
MAX_REQUEST_SIZE=10485760
MAX_FILE_SIZE_BYTES=10485760

# ============================================================
# 增量分析
# ============================================================
INCREMENTAL_MAX_CHANGE_RATIO=0.3
INCREMENTAL_MAX_PROPAGATION_DEPTH=3
INCREMENTAL_MAX_SNAPSHOT_VERSIONS=5

# ============================================================
# Celery
# ============================================================
# 开发环境同步执行方便调试；生产环境设为 false 并配合独立 Redis/RabbitMQ
CELERY_TASK_ALWAYS_EAGER=true

# ============================================================
# Redis 键 TTL（秒）
# ============================================================
REDIS_TASK_MAPPING_TTL=604800
REDIS_CANCEL_FLAG_TTL=60

# ============================================================
# 数据入库
# ============================================================
INGEST_BATCH_SIZE=500

# ============================================================
# 向量嵌入
# ============================================================
# ⚠️ 必须与使用的 Embedding 模型维度一致
EMBEDDING_DIMENSION=768
