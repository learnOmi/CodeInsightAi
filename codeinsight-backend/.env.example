# 环境变量配置示例
# 复制为 .env 后填写实际值
# ⚠️ 生产环境必须配置 POSTGRES_PASSWORD、SECRET_KEY、API_KEY

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codeinsight
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
# ⚠️ 生产环境必须配置，使用 32+ 字符随机密码
POSTGRES_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# LLM
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxx
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# 本地模型（可选）
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# JWT（预留，后续用户系统启用）
# ⚠️ 生产环境必须配置，使用 32+ 字符随机值
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Key 认证
# ⚠️ 生产环境必须配置；留空时跳过认证（仅开发环境）
API_KEY=

# 应用
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
