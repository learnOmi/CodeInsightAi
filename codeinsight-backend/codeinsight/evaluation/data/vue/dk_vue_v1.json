      "id": "DK-VUE-001",
      "description": "E-commerce product catalog domain",
      "code_snippets": [{
        "file": "stores/products.ts",
        "start_line": 1,
        "end_line": 55,
        "content": "import { defineStore } from 'pinia'\nimport { ref, computed } from 'vue'\n\nexport interface Product {\n  id: string\n  name: string\n  description: string\n  price: number\n  currency: string\n  category: string\n  subcategory?: string\n  tags: string[]\n  images: string[]\n  stock: number\n  rating: number\n  reviewCount: number\n  isActive: boolean\n  createdAt: string\n  updatedAt: string\n}\n\nexport interface FilterState {\n  categories: string[]\n  priceRange: [number, number]\n  minRating: number\n  inStockOnly: boolean\n  searchQuery: string\n  sortBy: 'price' | 'name' | 'rating' | 'createdAt'\n  sortOrder: 'asc' | 'desc'\n}\n\nexport const useProductStore = defineStore('products', () => {\n  const products = ref<Product[]>([])\n  const filters = ref<FilterState>({\n    categories: [],\n    priceRange: [0, 10000],\n    minRating: 0,\n    inStockOnly: false,\n    searchQuery: '',\n    sortBy: 'createdAt',\n    sortOrder: 'desc'\n  })\n\n  const filteredProducts = computed(() => {\n    let result = [...products.value]\n\n    if (filters.value.searchQuery) {\n      const q = filters.value.searchQuery.toLowerCase()\n      result = result.filter(p =>\n        p.name.toLowerCase().includes(q) ||\n        p.description.toLowerCase().includes(q) ||\n        p.tags.some(t => t.toLowerCase().includes(q))\n      )\n    }\n\n    if (filters.value.categories.length > 0) {\n      result = result.filter(p => filters.value.categories.includes(p.category))\n    }\n\n    result = result.filter(p =>\n      p.price >= filters.value.priceRange[0] &&\n      p.price <= filters.value.priceRange[1]\n    )\n\n    if (filters.value.inStockOnly) {\n      result = result.filter(p => p.stock > 0)\n    }\n\n    result.sort((a, b) => {\n      const aVal = a[filters.value.sortBy]\n      const bVal = b[filters.value.sortBy]\n      return filters.value.sortOrder === 'desc' ? bVal - aVal : aVal - bVal\n    })\n\n    return result\n  })\n\n  const categories = computed(() => {\n    const cats = new Set(products.value.map(p => p.category))\n    return Array.from(cats)\n  })\n\n  function addProduct(product: Omit<Product, 'id' | 'createdAt' | 'updatedAt'>) {\n    products.value.push({\n      ...product,\n      id: crypto.randomUUID(),\n      createdAt: new Date().toISOString(),\n      updatedAt: new Date().toISOString()\n    })\n  }\n\n  function updateStock(productId: string, delta: number) {\n    const product = products.value.find(p => p.id === productId)\n    if (product) {\n      product.stock = Math.max(0, product.stock + delta)\n      product.updatedAt = new Date().toISOString()\n    }\n  }\n\n  return { products, filters, filteredProducts, categories, addProduct, updateStock }\n})",
        "highlighted_lines": [1, 5, 10, 20, 30, 40, 50]
      }],
      "expected_points": [{
        "category": "DK",
        "prefix": "DK-ProductCatVUE",
        "title": "电商商品目录领域",
        "description": "实现电商商品目录的完整领域模型。Product接口定义商品的完整属性：基本信息（名称、描述、价格、货币）、分类层级（category、subcategory）、标签、图片、库存、评分和审核状态。FilterState管理多条件筛选：分类多选、价格范围滑块、最低评分、仅显示有货、全文搜索（名称+描述+标签）。useProductStore使用computed派生filteredProducts，链式应用搜索、分类、价格、库存过滤和排序。categories计算所有可用分类。addProduct和updateStock管理商品CRUD。这种领域模型支持复杂的产品浏览和搜索体验。",
        "confidence": 0.95,
        "alternative_titles": ["Product Catalog", "E-commerce Products", "Inventory Display"]
      }]
