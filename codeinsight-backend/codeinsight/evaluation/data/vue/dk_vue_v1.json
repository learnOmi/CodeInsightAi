    {
      "id": "DK-VUE-006",
      "description": "Code editor integration domain",
      "code_snippets": [{
        "file": "components/CodeEditor.vue",
        "start_line": 1,
        "end_line": 55,
        "content": "<template>\n  <div class=\"code-editor\" :class=\"{ 'dark-theme': theme === 'dark' }\">\n    <div class=\"editor-toolbar\">\n      <select v-model=\"language\" @change=\"onLanguageChange\">\n        <option value=\"javascript\">JavaScript</option>\n        <option value=\"typescript\">TypeScript</option>\n        <option value=\"python\">Python</option>\n        <option value=\"html\">HTML</option>\n        <option value=\"css\">CSS</option>\n        <option value=\"json\">JSON</option>\n      </select>\n      <button @click=\"copyCode\">Copy</button>\n      <button @click=\"toggleTheme\">{{ theme === 'dark' ? 'Light' : 'Dark' }}</button>\n    </div>\n    <div class=\"editor-container\">\n      <div class=\"line-numbers\" v-html=\"lineNumbers\" />:\n      <textarea\n        ref=\"textareaRef\"\n        v-model=\"code\"\n        @input=\"onCodeChange\"\n        @keydown.tab.prevent=\"insertTab\"\n        spellcheck=\"false\"\n        class=\"code-textarea\"\n      />\n    </div>\n    <div class=\"status-bar\">\n      <span>Ln {{ cursorLine }}, Col {{ cursorCol }}</span>\n      <span>{{ language }}</span>\n      <span>{{ charCount }} chars</span>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, watch, onMounted } from 'vue'\n\nconst props = defineProps<{ modelValue: string; language?: string }>()\nconst emit = defineEmits(['update:modelValue', 'change'])\n\nconst code = ref(props.modelValue)\nconst language = ref(props.language || 'javascript')\nconst theme = ref<'light' | 'dark'>('dark')\nconst textareaRef = ref<HTMLTextAreaElement | null>(null)\n\nconst lineNumbers = computed(() => {\n  const lines = code.value.split('\\n').length\n  return Array.from({ length: lines }, (_, i) => i + 1).join('<br>')\n})\n\nconst cursorPosition = ref({ line: 1, col: 1 })\nconst cursorLine = computed(() => cursorPosition.value.line)\nconst cursorCol = computed(() => cursorPosition.value.col)\nconst charCount = computed(() => code.value.length)\n\nfunction onCodeChange() {\n  emit('update:modelValue', code.value)\n  emit('change', { code: code.value, language: language.value })\n}\n\nfunction insertTab(event: KeyboardEvent) {\n  const el = event.target as HTMLTextAreaElement\n  const start = el.selectionStart\n  const end = el.selectionEnd\n  code.value = code.value.substring(0, start) + '  ' + code.value.substring(end)\n  el.selectionStart = el.selectionEnd = start + 2\n}\n\nwatch(code, (newVal) => {\n  updateCursorPosition()\n})\n\nfunction updateCursorPosition() {\n  const el = textareaRef.value\n  if (!el) return\n  const textBefore = code.value.substring(0, el.selectionStart)\n  const lines = textBefore.split('\\n')\n  cursorPosition.value = { line: lines.length, col: lines[lines.length - 1].length + 1 }\n}\n</script>",
        "highlighted_lines": [1, 5, 10, 20, 30, 40, 50]
      }],
