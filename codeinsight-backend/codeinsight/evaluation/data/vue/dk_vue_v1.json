        "end_line": 55,
        "content": "<template>\n  <div class=\"analytics-dashboard\">\n    <TimeRangeSelector v-model=\"dateRange\" @change=\"refreshData\" />\n    \n    <div class=\"kpi-row\">\n      <KPICard title=\"Page Views\" :value=\"stats.pageViews\" :change=\"stats.pageViewsChange\" />\n      <KPICard title=\"Unique Visitors\" :value=\"stats.visitors\" :change=\"stats.visitorsChange\" />\n      <KPICard title=\"Bounce Rate\" :value=\"`${stats.bounceRate}%`\" :change=\"stats.bounceRateChange\" />\n      <KPICard title=\"Avg. Session\" :value=\"formatDuration(stats.avgSession)\" />\n    </div>\n\n    <div class=\"charts-grid\">\n      <LineChart\n        title=\"Traffic Over Time\"\n        :data=\"trafficChartData\"\n        :x-axis=\"['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']\"\n      />\n      <BarChart\n        title=\"Traffic by Source\"\n        :data=\"sourceChartData\"\n      />\n      <PieChart\n        title=\"Device Distribution\"\n        :data=\"deviceChartData\"\n      />\n      <HeatmapChart\n        title=\"Activity Heatmap\"\n        :data=\"heatmapData\"\n      />\n    </div>\n\n    <TopPagesTable :pages=\"topPages\" />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, watch } from 'vue'\nimport { useAnalyticsStore } from '@/stores/analytics'\n\nconst dateRange = ref<'7d' | '30d' | '90d' | 'all'>('7d')\nconst analyticsStore = useAnalyticsStore()\n\nconst stats = computed(() => analyticsStore.getCurrentStats(dateRange.value))\n\nconst trafficChartData = computed(() => analyticsStore.getTrafficTimeline(dateRange.value))\nconst sourceChartData = computed(() => analyticsStore.getSourceBreakdown(dateRange.value))\nconst deviceChartData = computed(() => analyticsStore.getDeviceDistribution(dateRange.value))\nconst heatmapData = computed(() => analyticsStore.getActivityHeatmap(dateRange.value))\nconst topPages = computed(() => analyticsStore.getTopPages(dateRange.value, 10))\n\nfunction refreshData() {\n  analyticsStore.fetchData(dateRange.value)\n}\n\nfunction formatDuration(seconds: number): string {\n  const m = Math.floor(seconds / 60)\n  const s = seconds % 60\n  return `${m}m ${s}s`\n}\n</script>",
        "highlighted_lines": [1, 5, 10, 20, 30, 40, 50]
      }],
