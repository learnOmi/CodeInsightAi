    {
      "id": "DK-VUE-003",
      "description": "Real-time chat UI domain",
      "code_snippets": [{
        "file": "components/chat/ChatWindow.vue",
        "start_line": 1,
        "end_line": 55,
        "content": "<template>\n  <div class=\"chat-window\">\n    <header class=\"chat-header\">\n      <Avatar :user=\"room.participants[0]\" />\n      <span class=\"room-name\">{{ room.name }}</span>\n      <span class=\"online-count\">{{ onlineCount }} online</span>\n    </header>\n\n    <div class=\"messages-area\" ref=\"messagesContainer\" @scroll=\"handleScroll\">\n      <div v-if=\"isLoading\" class=\"loading-indicator\">Loading messages...</div>\n\n      <MessageBubble\n        v-for=\"msg in visibleMessages\" :key=\"msg.id\"\n        :message=\"msg\"\n        :is-current-user=\"msg.senderId === currentUserId\"\n        :show-timestamp=\"shouldShowTimestamp(msg)\"\n      />\n\n      <TransitionGroup name=\"typing\">\n        <div v-if=\"isTyping\" key=\"typing\" class=\"typing-indicator\">\n          {{ typingUser }} is typing...\n        </div>\n      </TransitionGroup>\n    </div>\n\n    <footer class=\"chat-input-area\">\n      <ReactionPicker @select=\"addReaction\" />\n      <textarea\n        v-model=\"inputText\"\n        placeholder=\"Type a message...\"\n        @keydown.enter.exact.prevent=\"sendMessage\"\n        @input=\"handleTyping\"\n      />\n      <button @click=\"sendMessage\" :disabled=\"!inputText.trim()\">Send</button>\n    </footer>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, watch, nextTick } from 'vue'\nimport { useChatStore } from '@/stores/chat'\n\nconst props = defineProps<{ roomId: string }>()\nconst chatStore = useChatStore()\nconst messagesContainer = ref<HTMLElement | null>(null)\n\nconst room = computed(() => chatStore.getRoom(props.roomId))\nconst messages = computed(() => chatStore.getMessages(props.roomId))\nconst onlineCount = computed(() => room.value?.participants.filter(p => p.online).length ?? 0)\n\nconst visibleMessages = computed(() => {\n  const start = Math.max(0, messages.value.length - 100)\n  return messages.value.slice(start)\n})\n\nfunction shouldShowTimestamp(msg: Message) {\n  const idx = messages.value.findIndex(m => m.id === msg.id)\n  if (idx === 0) return true\n  const prev = messages.value[idx - 1]\n  return !prev || (msg.timestamp.getTime() - prev.timestamp.getTime()) > 300000\n}\n\nasync function sendMessage() {\n  if (!inputText.value.trim()) return\n  await chatStore.sendMsg(props.roomId, inputText.value.trim())\n  inputText.value = ''\n  scrollToBottom()\n}\n\nfunction scrollToBottom() {\n  nextTick(() => {\n    if (messagesContainer.value) {\n      messagesContainer.value.scrollTop = messagesContainer.value.scrollHeight\n    }\n  })\n}\n</script>",
        "highlighted_lines": [1, 5, 10, 20, 30, 40, 50]
      }],
      "expected_points": [{
        "category": "DK",
        "prefix": "DK-ChatUIVUE",
        "title": "实时聊天界面领域",
        "description": "实现实时聊天界面的核心功能。ChatWindow组件包含Header（房间名、在线人数）、MessagesArea（消息列表、加载指示器、打字状态）和InputArea（表情选择、输入框、发送按钮）。visibleMessages使用slice限制只显示最近100条消息保证性能。shouldShowTimestamp只在消息间隔超过5分钟或第一条时显示时间戳。sendMessage通过chatStore发送消息并自动滚动到底部。typing indicator显示对方正在输入的状态。ReactionPicker支持表情回应。这种设计模拟了WhatsApp、Slack等主流聊天应用的UI模式。",
        "confidence": 0.95,
        "alternative_titles": ["Chat UI", "Messaging Interface", "Real-time Chat"]
      }]
