        "content": "<template>\n  <div class=\"kanban-board\">\n    <div class=\"board-header\">\n      <h2>{{ boardTitle }}</h2>\n      <button @click=\"addColumn\">+ Add Column</button>\n    </div>\n    \n    <div class=\"board-columns\" ref=\"boardContainer\">\n      <Draggable\n        v-for=\"column in columns\" :key=\"column.id\"\n        :list=\"column.tasks\" group=\"tasks\"\n        item-key=\"id\"\n        class=\"column\"\n        @change=\"onTaskMove\"\n      >\n        <template #item=\"{ element: task }\">\n          <TaskCard\n            :task=\"task\"\n            :column-id=\"column.id\"\n            @edit=\"openEditModal(task)\"\n            @delete=\"removeTask(task.id)\"\n            @priority-change=\"updatePriority(task, $event)\"\n          />\n        </template>\n      </Draggable>\n\n      <div class=\"add-column\" @click=\"addColumn\">\n        <span>+ New Column</span>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed } from 'vue'\nimport Draggable from 'vuedraggable'\n\ninterface Task {\n  id: string\n  title: string\n  description: string\n  priority: 'low' | 'medium' | 'high' | 'urgent'\n  assignee?: string\n  dueDate?: string\n  labels: string[]\n  createdAt: string\n}\n\ninterface Column {\n  id: string\n  title: string\n  tasks: Task[]\n  limit?: number\n}\n\nconst boardTitle = ref('Project Board')\nconst columns = ref<Column[]>([\n  { id: 'todo', title: 'To Do', tasks: [] },\n  { id: 'in-progress', title: 'In Progress', tasks: [] },\n  { id: 'review', title: 'Review', tasks: [] },\n  { id: 'done', title: 'Done', tasks: [] }\n])\n\nfunction addColumn() {\n  columns.value.push({\n    id: `col-${Date.now()}`,\n    title: 'New Column',\n    tasks: []\n  })\n}\n\nfunction onTaskMove(event: any) {\n  // Handle task moved between columns\n  console.log('Task moved:', event.moved)\n}\n\nfunction removeTask(taskId: string) {\n  for (const col of columns.value) {\n    const idx = col.tasks.findIndex(t => t.id === taskId)\n    if (idx !== -1) {\n      col.tasks.splice(idx, 1)\n      break\n    }\n  }\n}\n</script>",
