        "content": "<template>\n  <div class=\"dashboard\">\n    <div class=\"metrics-grid\">\n      <MetricCard\n        v-for=\"metric in metrics\" :key=\"metric.key\"\n        :title=\"metric.title\"\n        :value=\"metric.value\"\n        :change=\"metric.change\"\n        :icon=\"metric.icon\"\n        :trend=\"metric.trend\"\n      />\n    </div>\n\n    <div class=\"charts-row\">\n      <ChartCard title=\"Revenue Trend\" :chart-data=\"revenueData\" />\n      <ChartCard title=\"User Growth\" :chart-data=\"userGrowthData\" />\n    </div>\n\n    <DataTable\n      title=\"Recent Orders\"\n      :columns=\"orderColumns\"\n      :data=\"recentOrders\"\n      @row-click=\"viewOrderDetail\"\n    />\n\n    <ActivityFeed :activities=\"recentActivities\" />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, onMounted } from 'vue'\nimport { useDashboardStore } from '@/stores/dashboard'\n\nconst store = useDashboardStore()\n\ninterface MetricItem {\n  key: string\n  title: string\n  value: string | number\n  change: number\n  icon: string\n  trend: 'up' | 'down' | 'flat'\n}\n\nconst metrics = computed<MetricItem[]>(() => [\n  { key: 'revenue', title: 'Total Revenue', value: `$${store.totalRevenue}`, change: 12.5, icon: 'dollar', trend: 'up' },\n  { key: 'users', title: 'Active Users', value: store.activeUsers.toLocaleString(), change: 8.2, icon: 'users', trend: 'up' },\n  { key: 'orders', title: 'Today Orders', value: store.todayOrders, change: -3.1, icon: 'cart', trend: 'down' },\n  { key: 'conversion', title: 'Conversion Rate', value: `${store.conversionRate}%`, change: 1.8, icon: 'chart', trend: 'up' }\n])\n\nconst orderColumns = [\n  { key: 'id', label: 'Order ID' },\n  { key: 'customer', label: 'Customer' },\n  { key: 'total', label: 'Total' },\n  { key: 'status', label: 'Status' }\n]\n\nfunction viewOrderDetail(orderId: string) {\n  router.push(`/admin/orders/${orderId}`)\n}\n</script>",
        "highlighted_lines": [1, 5, 10, 20, 30, 40, 50]
      }],
      "expected_points": [{
        "category": "DK",
