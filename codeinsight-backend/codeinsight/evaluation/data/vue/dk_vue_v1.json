        "content": "<template>\n  <div class=\"form-builder\">\n    <div class=\"field-list\">\n      <draggable v-model=\"fields\" item-key=\"id\" handle=\".drag-handle\">\n        <template #item=\"{ element: field }\">\n          <div class=\"field-item\" :class=\"{ active: selectedField?.id === field.id }\">\n            <span class=\"drag-handle\">::</span>\n            <span class=\"field-label\">{{ field.label }}</span>\n            <span class=\"field-type\">{{ field.type }}</span>\n            <button @click=\"deleteField(field.id)\">Delete</button>\n          </div>\n        </template>\n      </draggable>\n    </div>\n\n    <div class=\"field-editor\" v-if=\"selectedField\">\n      <h3>Edit Field: {{ selectedField.label }}</h3>\n      <label>Label: <input v-model=\"selectedField.label\" /></label>\n      <label>Required: <input type=\"checkbox\" v-model=\"selectedField.required\" /></label>\n      <label>Placeholder: <input v-model=\"selectedField.placeholder\" /></label>\n      <label v-if=\"selectedField.options\">\n        Options: <input v-model=\"selectedField.options\" placeholder=\"comma-separated\" />\n      </label>\n      <label v-if=\"selectedField.validation\">\n        Min Length: <input type=\"number\" v-model.number=\"selectedField.validation.minLength\" />\n      </label>\n    </div>\n\n    <div class=\"preview-panel\">\n      <h3>Preview</h3>\n      <form @submit.prevent=\"handleSubmit\">\n        <FormField\n          v-for=\"field in fields\" :key=\"field.id\"\n          :field=\"field\"\n          v-model=\"formData[field.id]\"\n          :errors=\"fieldErrors[field.id]\"\n        />\n        <button type=\"submit\">Submit</button>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed } from 'vue'\nimport draggable from 'vuedraggable'\n\ninterface FormFieldConfig {\n  id: string\n  type: 'text' | 'email' | 'number' | 'select' | 'textarea' | 'checkbox'\n  label: string\n  required: boolean\n  placeholder?: string\n  options?: string\n  validation?: { minLength?: number; maxLength?: number; pattern?: string }\n}\n\nconst fields = ref<FormFieldConfig[]>([\n  { id: 'name', type: 'text', label: 'Full Name', required: true },\n  { id: 'email', type: 'email', label: 'Email', required: true },\n  { id: 'message', type: 'textarea', label: 'Message', required: false }\n])\n\nconst formData = ref<Record<string, any>>({})\nconst fieldErrors = ref<Record<string, string[]>>({})\n\nconst selectedField = computed(() => fields.value.find(f => f.id === selectedFieldId.value))\n\nfunction handleSubmit() {\n  // Validate and submit form data\n  validateForm()\n}\n</script>",
